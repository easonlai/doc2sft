# ==========================================
# DOC2SFT ENVIRONMENT TEMPLATE
# Optimized for: MacBook Pro (M5 Pro / 24GB RAM) & Qwen3 14B
# ==========================================

# ==========================================
# LLM & ENDPOINT CONFIGURATION
# ==========================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
# Leave blank for local execution. Populate if using a secured remote endpoint.
OLLAMA_SECRET=

# ==========================================
# DIRECTORY MAPPING
# ==========================================
INPUT_DIR=./data_input
OUTPUT_DIR=./data_output
LOG_DIR=./logs

# ==========================================
# PIPELINE BEHAVIOR & OUTPUT FORMAT
# ==========================================
# Target number of QA/CoT pairs to generate across all documents
TARGET_YIELD=50

# Set to 'True' to automatically ignore the Safe Yield hallucination warning
AUTO_BYPASS_WARNING=False

# Generation Mode. Options: 'qa' (Direct Answer) or 'cot' (Chain-of-Thought reasoning)
GENERATION_STYLE=qa

# Target Language for the generated training data
TARGET_LANGUAGE=English

# Export structure. Options: 'sharegpt' (Standard for MLX/HuggingFace) or 'alpaca'
EXPORT_FORMAT=sharegpt

# LLM Temperature. Keep low (0.1 - 0.2) for factual document extraction.
TEMPERATURE=0.1

# Set to 'auto' for dynamic domain detection, or hardcode a specific persona string.
SYSTEM_PROMPT=auto

# ==========================================
# ADVANCED MECHANISMS
# ==========================================
# Minimum quality score from the AI Judge (1-5). 
# Set to 4. A 14B model is highly capable of acting as a strict enterprise Auditor.
MIN_QUALITY_SCORE=4

# Path to store the checkpoint file for resuming interrupted runs.
CHECKPOINT_FILE=./logs/state.json

# ==========================================
# HARDWARE & CONTEXT OPTIMIZATION (RAM/VRAM)
# ==========================================
# Number of concurrent chunks processed simultaneously. 
# 24GB RAM allows Ollama to easily batch requests against the ~8.5GB model weights.
CONCURRENCY_LIMIT=2

# Context Window sizes (Total input + output tokens the model can hold in memory).
OLLAMA_NUM_CTX_QA=4096
OLLAMA_NUM_CTX_COT=8192

# Maximum generation length per API call (Max output tokens).
OLLAMA_NUM_PREDICT_QA=1000
OLLAMA_NUM_PREDICT_COT=2500