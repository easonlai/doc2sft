# ==========================================
# 1. Environment & Secrets (CRITICAL)
# ==========================================
.env
.env.*
!.env.example*

# ==========================================
# 2. Project Data & Logs
# ==========================================
# Ignore all files inside these directories...
data_input/*
data_output/*
logs/*

# ...but keep the directories themselves in the repository
!data_input/.gitkeep
!data_output/.gitkeep
!logs/.gitkeep

# Ignore backup JSONL files generated by the anti-duplication defense
data_output/*_backup_*.jsonl

# ==========================================
# 3. Python Virtual Environments & Cache
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env_dir/

# uv specific
.uv/

# ==========================================
# 4. OS Specific Files (macOS/Windows)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db